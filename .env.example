# Django
SECRET_KEY=change-me-in-production
DEBUG=True

# Hosts permitidos, separados por vírgula e sem http:// ou https://
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens confiáveis completas, incluindo o protocolo
CSRF_TRUSTED_ORIGINS=http://localhost:8800,http://127.0.0.1:8800

# Segurança HTTPS
# Em produção com Cloudflare Tunnel, usar True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Ativar somente depois de confirmar o funcionamento do proxy HTTPS
SECURE_SSL_REDIRECT=False

# Banco
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Para PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sst_freedom
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# ConsultaCA Integration Configuration
# CONSULTACA_ENABLED=True
# CONSULTACA_BASE_URL=https://consultaca.com
# CONSULTACA_CONNECT_TIMEOUT=3
# CONSULTACA_READ_TIMEOUT=5
# CONSULTACA_CACHE_TIMEOUT=86400
# CONSULTACA_NOT_FOUND_CACHE_TIMEOUT=3600
# CONSULTACA_MAX_RESPONSE_BYTES=1048576

# Exemplo de produção:
# DEBUG=False
# ALLOWED_HOSTS=sst.freedom.dev.br,192.168.0.202,127.0.0.1,localhost
# CSRF_TRUSTED_ORIGINS=https://sst.freedom.dev.br
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=False
